# Cloudflare R2 credentials (S3-compatible). podpush uploads audio + feed.xml here.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL the bucket is served from (r2.dev or your custom domain).
R2_PUBLIC_URL=https://pub-<hash>.r2.dev
