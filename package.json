{
  "name": "shipcast",
  "version": "0.1.0",
  "description": "Push podcast episodes to your own R2-backed RSS feed from the terminal.",
  "type": "module",
  "license": "MIT",
  "author": "Etienne de Bruin",
  "repository": "github:everydev1618/shipcast",
  "homepage": "https://github.com/everydev1618/shipcast",
  "keywords": ["podcast", "rss", "cloudflare", "r2", "cli", "publishing", "ffmpeg"],
  "bin": {
    "shipcast": "./src/cli.ts"
  },
  "files": ["src", "worker", "README.md", "LICENSE"],
  "scripts": {
    "shipcast": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "tsx": "^4.22.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22.10.0",
    "eslint": "^9",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.6"
  }
}
