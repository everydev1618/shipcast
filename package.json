{
  "name": "podpush",
  "version": "0.1.0",
  "description": "Push podcast episodes to your own R2-backed RSS feed from the terminal.",
  "type": "module",
  "bin": {
    "podpush": "./src/cli.ts"
  },
  "scripts": {
    "podpush": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1048.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22.10.0",
    "eslint": "^9",
    "tsx": "^4.22.1",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^4.1.6"
  }
}
